---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../config';
import { translations as tr } from '../i18n/translations';

const en = tr.en;
const de = tr.de;
const titleEn = en.error404Title(SITE_TITLE);
const titleDe = de.error404Title(SITE_TITLE);
const descriptionEn = en.error404Meta;
const descriptionDe = de.error404Meta;

// SEO default = DE
const title = titleDe;
const description = descriptionDe;
---

<BaseLayout title={title} description={description}>
  <main id="main" class="error-page">
    <div class="container">
      <p class="error-code">404</p>
      <h1 data-lang-pair>
        <span data-lang="en">{en.error404Heading}</span>
        <span data-lang="de">{de.error404Heading}</span>
      </h1>
      <p class="error-message">
        <span data-lang="en">{en.error404Message}</span>
        <span data-lang="de">{de.error404Message}</span>
      </p>
      <a href="/" class="button button-primary" data-lang-pair>
        <span data-lang="en">{en.error404Back}</span>
        <span data-lang="de">{de.error404Back}</span>
      </a>
    </div>
  </main>

  <script define:vars={{ titleEn, titleDe, descriptionEn, descriptionDe }}>
    document.addEventListener('langchange', (e) => {
      const lang = e.detail?.lang ?? 'de';
      document.title = lang === 'en' ? titleEn : titleDe;
      const meta = document.querySelector('meta[name="description"]');
      if (meta) meta.setAttribute('content', lang === 'en' ? descriptionEn : descriptionDe);
    });
  </script>
</BaseLayout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-block: 6rem;
    text-align: center;
  }

  .error-code {
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .error-page h1 {
    margin-bottom: 1rem;
  }

  .error-message {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 45ch;
    margin-inline: auto;
  }
</style>