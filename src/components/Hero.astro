---
import { translations as tr } from '../i18n/translations';

const en = tr.en;
const de = tr.de;
---

<header class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-eyebrow">
          <span data-lang="en">{en.heroEyebrow}</span>
          <span data-lang="de">{de.heroEyebrow}</span>
        </p>
        <h1>{en.heroTitle}</h1>
        <p class="hero-tagline">
          <span data-lang="en">{en.heroTagline}</span>
          <span data-lang="de">{de.heroTagline}</span>
        </p>
        <p class="hero-summary">
          <span data-lang="en">{en.heroSummary}</span>
          <span data-lang="de">{de.heroSummary}</span>
        </p>
        <div class="hero-actions">
          <a href="#experience" class="button button-primary" data-lang-pair>
            <span data-lang="en">{en.heroCtaExperience}</span>
            <span data-lang="de">{de.heroCtaExperience}</span>
          </a>
          <a href="#contact" class="button button-secondary" data-lang-pair>
            <span data-lang="en">{en.heroCtaContact}</span>
            <span data-lang="de">{de.heroCtaContact}</span>
          </a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-title">status</span>
          </div>
          <div class="terminal-body">
            <p><span class="terminal-prompt">$</span> whoami</p>
            <p class="terminal-output">herbert_nikolajewski</p>
            <p data-lang="en"><span class="terminal-prompt">$</span> {en.terminalCurrentFocus}</p>
            <p data-lang="de"><span class="terminal-prompt">$</span> {de.terminalCurrentFocus}</p>
            <p class="terminal-output">self-hosted infrastructure, k8s, terraform</p>
            <p data-lang="en"><span class="terminal-prompt">$</span> {en.terminalLocation}</p>
            <p data-lang="de"><span class="terminal-prompt">$</span> {de.terminalLocation}</p>
            <p class="terminal-output">
              <span data-lang="en">{en.terminalLocationValue}</span>
              <span data-lang="de">{de.terminalLocationValue}</span>
            </p>
            <p><span class="terminal-prompt">$</span> <span class="terminal-cursor">_</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>