---
import { getCollection } from 'astro:content';

const skillsEntries = await getCollection('skills');
const skillsEntry = skillsEntries[0];
// The file loader returns the JSON root array directly as `data`.
const categories = (skillsEntry?.data as any) ?? [];

const levelLabels: Record<string, string> = {
  production: 'In production',
  teaching: 'Taught & used',
  experimental: 'Experimenting',
};

const tagGroupMap: Record<string, string> = {
  TypeScript: 'frontend',
  JavaScript: 'frontend',
  'Node.js': 'backend',
  Bash: 'devops',
  'React.js': 'frontend',
  Astro: 'frontend',
  EJS: 'frontend',
  'HTML/CSS': 'frontend',
  'Express.js': 'backend',
  'MERN Stack': 'backend',
  'REST APIs': 'backend',
  Docker: 'devops',
  Kubernetes: 'devops',
  Terraform: 'devops',
  Ansible: 'devops',
  'CI/CD': 'devops',
  'GitHub Actions': 'devops',
  MongoDB: 'backend',
  PostgreSQL: 'backend',
  MySQL: 'backend',
  Linux: 'other',
  Automation: 'other',
  'Web Performance': 'other',
  Agile: 'other',
};

const groupLabels: Record<string, string> = {
  all: 'All',
  devops: 'DevOps',
  frontend: 'Frontend',
  backend: 'Backend',
  other: 'Other',
};

const groups = ['all', 'devops', 'frontend', 'backend', 'other'];
const initialFilter = 'all';

const totalSkills = categories.reduce((sum: number, category: any) => sum + category.items.length, 0);
---

<section id="skills" class="section">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Toolkit</p>
      <h2>Skills & Technologies</h2>
    </div>

    <div class="skills-filter reveal" role="group" aria-label="Filter skills by area">
      {
        groups.map((group) => (
          <button
            type="button"
            class={`filter-button${group === initialFilter ? ' is-active' : ''}`}
            data-filter={group}
            aria-pressed={group === initialFilter ? 'true' : 'false'}
          >
            {groupLabels[group]}
          </button>
        ))
      }
    </div>

    <p class="skills-status" aria-live="polite" aria-atomic="true">
      Showing <strong>{totalSkills}</strong> skills
    </p>

    <div class="skills-list">
      {
        categories.map((category: any, categoryIndex: number) => (
          <div class="skill-category reveal" style={`--item-index: ${categoryIndex}`}>
            <h3>{category.category}</h3>
            <ul class="skill-tags">
              {category.items.map((item: any) => (
                <li class="skill-tag" data-level={item.level} data-group={tagGroupMap[item.name]}>
                  <span class="skill-name">{item.name}</span>
                  <span class="skill-level">{levelLabels[item.level]}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-button');
    const tags = document.querySelectorAll<HTMLLIElement>('.skill-tag');
    const status = document.querySelector<HTMLParagraphElement>('.skills-status');

    function updateStatus(visibleCount: number, totalCount: number, filterLabel: string) {
      if (!status) return;
      const label = filterLabel === 'All' ? 'all skills' : `${filterLabel.toLowerCase()} skills`;
      status.textContent = `Showing ${visibleCount} of ${totalCount} ${label}`;
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter ?? 'all';
        const filterLabel = button.textContent?.trim() ?? 'All';

        buttons.forEach((btn) => {
          const isSelected = btn === button;
          btn.classList.toggle('is-active', isSelected);
          btn.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
        });

        let visibleCount = 0;

        tags.forEach((tag) => {
          const group = tag.dataset.group ?? '';
          const matches = filter === 'all' || group === filter;
          tag.classList.toggle('is-hidden', !matches);
          tag.setAttribute('aria-hidden', matches ? 'false' : 'true');
          if (matches) visibleCount++;
        });

        updateStatus(visibleCount, tags.length, filterLabel);
      });
    });
  </script>
</section>
