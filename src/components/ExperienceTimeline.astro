---
import { getCollection } from 'astro:content';

const entries = await getCollection('experience');
const sortedEntries = entries.sort((a, b) => a.data.order - b.data.order);
---

<section id="experience" class="section section-muted">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Career</p>
      <h2>Experience</h2>
    </div>

    <div class="timeline">
      {
        sortedEntries.map((entry, index) => (
          <article class="timeline-item reveal" style={`--item-index: ${index}`}>
            <div class="timeline-marker" aria-hidden="true" />
            <div class="timeline-content">
              <header class="timeline-header">
                <div>
                  <h3>{entry.data.role}</h3>
                  <p class="timeline-company">{entry.data.company}</p>
                </div>
                <time class="timeline-date">{entry.data.date}</time>
              </header>
              <p class="timeline-location">{entry.data.location}</p>
              <div class="timeline-body">
                <ul>
                  {entry.data.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
