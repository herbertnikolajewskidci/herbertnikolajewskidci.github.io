---
import { AUTHOR, SOCIAL_LINKS } from '../config';
---

<section id="contact" class="section section-muted">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Contact</p>
      <h2>Let's build something solid.</h2>
    </div>

    <div class="contact-grid reveal">
      <div class="contact-primary">
        <p class="contact-lead">
          {AUTHOR.availability} If you need someone who can ship software and keep the infrastructure
          running, let's talk.
        </p>

        <div class="contact-email-row">
          <a href={`mailto:${AUTHOR.email}`} class="contact-email">{AUTHOR.email}</a>
          <button type="button" class="copy-email-button" data-email={AUTHOR.email} aria-label="Copy email address">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="copy-label">Copy</span>
          </button>
        </div>

        <p class="contact-response">I usually reply within 24 hours.</p>

        <div class="contact-actions">
          <a href={`mailto:${AUTHOR.email}`} class="button button-primary">Send an email</a>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="button button-secondary">
            View GitHub
          </a>
        </div>
      </div>

      <div class="contact-links">
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">herbert-nikolajewski</span>
        </a>
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <span class="contact-label">GitHub</span>
          <span class="contact-value">herbertnikolajewskidci</span>
        </a>
        <div class="contact-card contact-card-static">
          <span class="contact-label">Location</span>
          <span class="contact-value">{AUTHOR.location}</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('.copy-email-button');

    copyButton?.addEventListener('click', async () => {
      const email = copyButton.dataset.email;
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        const label = copyButton.querySelector<HTMLSpanElement>('.copy-label');
        const original = label?.textContent ?? 'Copy';
        if (label) label.textContent = 'Copied';
        copyButton.setAttribute('aria-label', 'Email address copied');
        setTimeout(() => {
          if (label) label.textContent = original;
          copyButton.setAttribute('aria-label', 'Copy email address');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy email:', err);
        copyButton.setAttribute('aria-label', 'Could not copy email address');
      }
    });
  </script>
</section>
