---
const email = 'herby.nik@googlemail.com';
---

<section id="contact" class="section section-muted">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Contact</p>
      <h2>Let's build something solid.</h2>
    </div>

    <div class="contact-grid reveal">
      <div class="contact-primary">
        <p class="contact-lead">
          Open for full-stack and DevOps roles in Regensburg, Germany, or remote. If you need someone
          who can ship software and keep the infrastructure running, let's talk.
        </p>
        <a href={`mailto:${email}`} class="contact-email">{email}</a>
        <div class="contact-actions">
          <a href={`mailto:${email}`} class="button button-primary">Send an email</a>
        </div>
      </div>

      <div class="contact-links">
        <a
          href="https://linkedin.com/in/herbert-nikolajewski"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">herbert-nikolajewski</span>
        </a>
        <a
          href="https://github.com/herbertnikolajewskidci"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <span class="contact-label">GitHub</span>
          <span class="contact-value">herbertnikolajewskidci</span>
        </a>
        <div class="contact-card">
          <span class="contact-label">Location</span>
          <span class="contact-value">Regensburg, Germany · Remote/Hybrid</span>
        </div>
      </div>
    </div>
  </div>
</section>
