---
import { AUTHOR, SOCIAL_LINKS } from '../config';
import { translations as tr } from '../i18n/translations';

const en = tr.en;
const de = tr.de;
---

<section id="contact" class="section section-muted">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">
        <span data-lang="en">{en.contactEyebrow}</span>
        <span data-lang="de">{de.contactEyebrow}</span>
      </p>
      <h2>
        <span data-lang="en">{en.contactHeading}</span>
        <span data-lang="de">{de.contactHeading}</span>
      </h2>
    </div>

    <div class="contact-grid reveal">
      <div class="contact-primary">
        <p class="contact-lead">
          <span data-lang="en">
            {en.contactAvailability} {en.contactLeadPart2}
          </span>
          <span data-lang="de">
            {de.contactAvailability} {de.contactLeadPart2}
          </span>
        </p>

        <div class="contact-email-row">
          <a href={`mailto:${AUTHOR.email}`} class="contact-email">{AUTHOR.email}</a>
          <button
            type="button"
            class="copy-email-button"
            data-email={AUTHOR.email}
            aria-label={en.contactCopyAria}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="copy-label" data-lang-pair>
              <span data-lang="en">{en.contactCopy}</span>
              <span data-lang="de">{de.contactCopy}</span>
            </span>
          </button>
        </div>

        <p class="contact-response">
          <span data-lang="en">{en.contactResponse}</span>
          <span data-lang="de">{de.contactResponse}</span>
        </p>

        <div class="contact-actions">
          <a href={`mailto:${AUTHOR.email}`} class="button button-primary" data-lang-pair>
            <span data-lang="en">{en.contactSendEmail}</span>
            <span data-lang="de">{de.contactSendEmail}</span>
          </a>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="button button-secondary" data-lang-pair>
            <span data-lang="en">{en.contactViewGithub}</span>
            <span data-lang="de">{de.contactViewGithub}</span>
          </a>
        </div>
      </div>

      <div class="contact-links">
        <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="contact-card">
          <span class="contact-label">
            <span data-lang="en">{en.contactCardLinkedInLabel}</span>
            <span data-lang="de">{de.contactCardLinkedInLabel}</span>
          </span>
          <span class="contact-value">{en.contactCardLinkedInValue}</span>
        </a>
        <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="contact-card">
          <span class="contact-label">
            <span data-lang="en">{en.contactCardGithubLabel}</span>
            <span data-lang="de">{de.contactCardGithubLabel}</span>
          </span>
          <span class="contact-value">{en.contactCardGithubValue}</span>
        </a>
        <div class="contact-card contact-card-static">
          <span class="contact-label">
            <span data-lang="en">{en.contactCardLocationLabel}</span>
            <span data-lang="de">{de.contactCardLocationLabel}</span>
          </span>
          <span class="contact-value">
            <span data-lang="en">{en.contactCardLocationValue}</span>
            <span data-lang="de">{de.contactCardLocationValue}</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('.copy-email-button');

    function currentLangLabel(en: string, de: string): string {
      return document.documentElement.lang === 'en' ? en : de;
    }

    copyButton?.addEventListener('click', async () => {
      const email = copyButton.dataset.email;
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        const label = copyButton.querySelector<HTMLSpanElement>('.copy-label');
        const labelVisible = label?.querySelector<HTMLElement>('[data-lang="en"]');
        const labelHidden = label?.querySelector<HTMLElement>('[data-lang="de"]');
        const okText = currentLangLabel('Copied', 'Kopiert');
        // Update the currently visible span only
        if (document.documentElement.lang === 'en' && labelVisible) labelVisible.textContent = okText;
        else if (labelHidden) labelHidden.textContent = okText;
        copyButton.setAttribute('aria-label', currentLangLabel('Email address copied', 'E-Mail-Adresse kopiert'));
        setTimeout(() => {
          if (document.documentElement.lang === 'en' && labelVisible) labelVisible.textContent = 'Copy';
          else if (labelHidden) labelHidden.textContent = 'Kopieren';
          copyButton.setAttribute('aria-label', currentLangLabel('Copy email address', 'E-Mail-Adresse kopieren'));
        }, 2000);
      } catch (err) {
        console.error('Failed to copy email:', err);
        copyButton.setAttribute('aria-label', currentLangLabel('Could not copy email address', 'E-Mail-Adresse konnte nicht kopiert werden'));
      }
    });
  </script>
</section>